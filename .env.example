# Copy this file to .env, then fill in your local values.
# Docker Compose reads .env automatically.

POSTGRES_USER=tg_reader
POSTGRES_PASSWORD=change_me
POSTGRES_DB=tg_reader
POSTGRES_PORT=5432

BACKEND_PORT=8000
FRONTEND_PORT=80

# Direct local backend runs use this URL. Docker overrides DATABASE_URL and
# connects the backend container to the db service automatically.
DATABASE_URL=postgresql+asyncpg://tg_reader:change_me@localhost:5432/tg_reader

API_ID=
API_HASH=
SESSION_NAME=telegram_session

# Optional Telegram proxy. Leave empty if Telegram is reachable directly.
PROXY_SCHEME=
PROXY_HOST=
PROXY_PORT=

TELEGRAM_SYNC_WAIT_TIME_SECONDS=0.5
TELEGRAM_REQUEST_MIN_INTERVAL_SECONDS=0.8
